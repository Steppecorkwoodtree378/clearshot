#!/usr/bin/env bash
# clearshot setup
set -e

# ─── colors & style ─────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
ITALIC='\033[3m'
CYAN='\033[36m'
GREEN='\033[32m'
MAGENTA='\033[35m'
YELLOW='\033[33m'
WHITE='\033[97m'
BLUE='\033[34m'
RESET='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_DIR="$HOME/.claude/skills/clearshot"
STATE_DIR="$HOME/.clearshot"
VERSION="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "1.2.0")"

clear 2>/dev/null || true

# ─── helper: typing effect ───────────────────────────────────
type_out() {
  local text="$1"
  local delay="${2:-0.02}"
  for (( i=0; i<${#text}; i++ )); do
    printf '%s' "${text:$i:1}"
    sleep "$delay" 2>/dev/null || true
  done
  echo ""
}

# ─── helper: pause for readability ───────────────────────────
pause() { sleep "${1:-0.3}" 2>/dev/null || true; }

# ─── logo ────────────────────────────────────────────────────
echo ""
echo ""
echo -e "   ${BOLD}${WHITE}┌─────────────────────────────────────────────┐${RESET}"
echo -e "   ${BOLD}${WHITE}│                                             │${RESET}"
echo -e "   ${BOLD}${WHITE}│${RESET}   ${BOLD}📸  c l e a r s h o t${RESET}   ${DIM}v${VERSION}${RESET}             ${BOLD}${WHITE}│${RESET}"
echo -e "   ${BOLD}${WHITE}│                                             │${RESET}"
echo -e "   ${BOLD}${WHITE}│${RESET}   ${DIM}your AI can finally see.${RESET}                  ${BOLD}${WHITE}│${RESET}"
echo -e "   ${BOLD}${WHITE}│                                             │${RESET}"
echo -e "   ${BOLD}${WHITE}└─────────────────────────────────────────────┘${RESET}"
echo ""
pause 0.5

# ─── the pitch ───────────────────────────────────────────────
echo -e "   ${BOLD}the problem${RESET}"
echo ""
pause 0.2
echo -e "   you paste a screenshot. the AI says:"
pause 0.3
echo ""
echo -e "   ${DIM}${ITALIC}\"i see a dashboard with some cards and a sidebar.\"${RESET}"
pause 0.5
echo ""
echo -e "   ${YELLOW}you${RESET}, staring at a broken button, wrong padding,"
echo -e "   inconsistent type scale, and a nav that makes no sense:"
pause 0.3
echo ""
echo -e "   ${DIM}${ITALIC}\"...are we looking at the same screen?\"${RESET}"
echo ""
pause 0.5

echo -e "   ${DIM}─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─${RESET}"
echo ""
pause 0.3

# ─── the fix ─────────────────────────────────────────────────
echo -e "   ${BOLD}the fix${RESET}"
echo ""
pause 0.2
echo -e "   clearshot runs a structured analysis ${ITALIC}before${RESET}"
echo -e "   the AI responds. it doesn't guess. it ${CYAN}knows${RESET}."
echo ""
pause 0.3
echo -e "   ${CYAN}→${RESET} not ${DIM}\"blue color\"${RESET} but ${CYAN}#3B82F6${RESET}"
echo -e "   ${CYAN}→${RESET} not ${DIM}\"some spacing\"${RESET} but ${CYAN}8px gap${RESET}"
echo -e "   ${CYAN}→${RESET} not ${DIM}\"a button\"${RESET} but ${CYAN}sm/rounded-md/border-gray-200/shadow-sm${RESET}"
echo ""
pause 0.5

echo -e "   ${DIM}─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─${RESET}"
echo ""
pause 0.3

# ─── the pipeline ────────────────────────────────────────────
echo -e "   ${BOLD}five-step pipeline${RESET} ${DIM}(runs only what's needed)${RESET}"
echo ""
pause 0.2
echo -e "   ${MAGENTA}①${RESET}  spatial grid        ${DIM}where everything lives${RESET}"
echo -e "   ${MAGENTA}②${RESET}  element inventory   ${DIM}every component, precisely${RESET}"
echo -e "   ${MAGENTA}③${RESET}  design tokens       ${DIM}colors, type, spacing${RESET}"
echo -e "   ${MAGENTA}④${RESET}  layout architecture ${DIM}flex, grid, constraints${RESET}"
echo -e "   ${MAGENTA}⑤${RESET}  interaction map     ${DIM}CTAs, nav, forms, states${RESET}"
echo ""
pause 0.3
echo -e "   ${DIM}\"clone this\" → all 5. \"looks right?\" → just ①.${RESET}"
echo -e "   ${DIM}it reads the room.${RESET}"
echo ""
pause 0.5

echo -e "   ${DIM}─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─${RESET}"
echo ""
pause 0.3

# ─── two brains ──────────────────────────────────────────────
echo -e "   ${BOLD}two brains${RESET}"
echo ""
pause 0.2
echo -e "   ${CYAN}🔬 analytical${RESET}   pixel-perfect. hex codes, measurements,"
echo -e "                  component types. the engineer brain."
echo ""
echo -e "   ${MAGENTA}🎨 qualitative${RESET}  does it ${ITALIC}feel${RESET} right? visual weight,"
echo -e "                  hierarchy, breathing room. the designer brain."
echo ""
pause 0.3
echo -e "   ${DIM}picks the right one automatically. or blends both.${RESET}"
echo ""
pause 0.5

echo -e "   ${DIM}─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─${RESET}"
echo ""
pause 0.3

# ─── smart enough to shut up ────────────────────────────────
echo -e "   ${BOLD}smart enough to shut up${RESET}"
echo ""
pause 0.2
echo -e "   screenshot of a meme? ${DIM}stays quiet.${RESET}"
echo -e "   architecture diagram? ${DIM}stays quiet.${RESET}"
echo -e "   photo of your lunch? ${DIM}definitely stays quiet.${RESET}"
echo ""
echo -e "   ${DIM}only wakes up for UI screenshots when you're${RESET}"
echo -e "   ${DIM}actually building or critiquing frontend.${RESET}"
echo ""
pause 0.5

echo -e "   ${WHITE}${BOLD}┌─────────────────────────────────────────────┐${RESET}"
echo -e "   ${WHITE}${BOLD}│${RESET}  ${BOLD}installing...${RESET}                              ${WHITE}${BOLD}│${RESET}"
echo -e "   ${WHITE}${BOLD}└─────────────────────────────────────────────┘${RESET}"
echo ""
pause 0.3

# ─── actual setup ────────────────────────────────────────────

# 1. local state
mkdir -p "$STATE_DIR/analytics"
mkdir -p "$STATE_DIR/feedback"
pause 0.2
echo -e "   ${GREEN}✓${RESET}  local state         ${DIM}~/.clearshot/${RESET}"

# 2. skill registration
mkdir -p "$HOME/.claude/skills"
if [ -L "$SKILL_DIR" ]; then
  _CURRENT_TARGET="$(readlink "$SKILL_DIR" 2>/dev/null || true)"
  if [ "$_CURRENT_TARGET" = "$SCRIPT_DIR" ]; then
    pause 0.2
    echo -e "   ${GREEN}✓${RESET}  skill registered    ${DIM}already linked${RESET}"
  else
    rm "$SKILL_DIR"
    ln -sf "$SCRIPT_DIR" "$SKILL_DIR"
    pause 0.2
    echo -e "   ${GREEN}✓${RESET}  skill registered    ${DIM}relinked${RESET}"
  fi
elif [ -d "$SKILL_DIR" ]; then
  rm -rf "$SKILL_DIR"
  ln -sf "$SCRIPT_DIR" "$SKILL_DIR"
  pause 0.2
  echo -e "   ${GREEN}✓${RESET}  skill registered    ${DIM}updated${RESET}"
else
  ln -sf "$SCRIPT_DIR" "$SKILL_DIR"
  pause 0.2
  echo -e "   ${GREEN}✓${RESET}  skill registered    ${DIM}~/.claude/skills/clearshot${RESET}"
fi

# 3. config
if [ ! -f "$STATE_DIR/config.yaml" ]; then
  cat > "$STATE_DIR/config.yaml" << 'YAML'
telemetry: off
update_mode: ask
YAML
  pause 0.2
  echo -e "   ${GREEN}✓${RESET}  config created      ${DIM}defaults set${RESET}"
else
  pause 0.2
  echo -e "   ${GREEN}✓${RESET}  config preserved    ${DIM}your settings are safe${RESET}"
fi

# 4. global instruction — ensures clearshot always triggers on UI screenshots
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
CLEARSHOT_MARKER="<!-- clearshot-trigger -->"
if ! grep -q "$CLEARSHOT_MARKER" "$CLAUDE_MD" 2>/dev/null; then
  mkdir -p "$HOME/.claude"
  cat >> "$CLAUDE_MD" << 'MD'

<!-- clearshot-trigger -->
## Screenshot analysis — BLOCKING REQUIREMENT

When the user shares, pastes, or references any image of a digital interface (website, app, dashboard, mockup, wireframe, Figma export, design comp, DevTools screenshot), this is a BLOCKING REQUIREMENT: invoke the Skill tool with `skill: "clearshot"` BEFORE generating any other response about the image. This applies to all projects and conversations. The only exceptions are clearly non-UI images (photos, memes, standalone charts, documents) unless the user explicitly asks for UI analysis.
MD
  pause 0.2
  echo -e "   ${GREEN}✓${RESET}  global trigger      ${DIM}~/.claude/CLAUDE.md${RESET}"
else
  pause 0.2
  echo -e "   ${GREEN}✓${RESET}  global trigger      ${DIM}already configured${RESET}"
fi

pause 0.3
echo ""

# ─── done ────────────────────────────────────────────────────
echo -e "   ${WHITE}${BOLD}┌─────────────────────────────────────────────┐${RESET}"
echo -e "   ${WHITE}${BOLD}│${RESET}                                             ${WHITE}${BOLD}│${RESET}"
echo -e "   ${WHITE}${BOLD}│${RESET}   ${GREEN}${BOLD}you're in.${RESET}                                ${WHITE}${BOLD}│${RESET}"
echo -e "   ${WHITE}${BOLD}│${RESET}                                             ${WHITE}${BOLD}│${RESET}"
echo -e "   ${WHITE}${BOLD}└─────────────────────────────────────────────┘${RESET}"
echo ""
pause 0.3

# ─── onboarding: two quick questions ──────────────────────────

source "$SCRIPT_DIR/bin/picker.sh"

# helper to write config values
_cs_set_config() {
  local key="$1" val="$2"
  if [ -f "$STATE_DIR/config.yaml" ] && grep -qE "^${key}:" "$STATE_DIR/config.yaml" 2>/dev/null; then
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "s/^${key}:.*/${key}: ${val}/" "$STATE_DIR/config.yaml"
    else
      sed -i "s/^${key}:.*/${key}: ${val}/" "$STATE_DIR/config.yaml"
    fi
  elif [ -f "$STATE_DIR/config.yaml" ]; then
    echo "${key}: ${val}" >> "$STATE_DIR/config.yaml"
  else
    echo "${key}: ${val}" > "$STATE_DIR/config.yaml"
  fi
}

echo -e "   ${BOLD}two quick questions${RESET} ${DIM}(↑/↓ + enter)${RESET}"
echo ""
pause 0.2

# Question 1: Updates
echo -e "   ${CYAN}①${RESET}  ${BOLD}how should clearshot update?${RESET}"
echo ""

pick 0 \
  "Always keep updated    auto-pull new versions" \
  "Ask me every time      prompt before updating"

if [ "$PICK_INDEX" -eq -1 ] || [ "$PICK_INDEX" -eq 1 ]; then
  _UPDATE_MODE="ask"
else
  _UPDATE_MODE="always"
fi
_cs_set_config "update_mode" "$_UPDATE_MODE"

echo ""
if [ "$_UPDATE_MODE" = "always" ]; then
  echo -e "   ${GREEN}✓${RESET}  updates: ${BOLD}auto${RESET}"
else
  echo -e "   ${GREEN}✓${RESET}  updates: ${BOLD}ask every time${RESET}"
fi
echo ""
pause 0.3

# Question 2: Telemetry
echo -e "   ${CYAN}②${RESET}  ${BOLD}anonymous telemetry?${RESET}"
echo -e "      ${DIM}usage events only. no screenshots, code, or content.${RESET}"
echo ""

pick 1 \
  "Anonymous              usage events + hashed device ID (no PII)" \
  "Off                    nothing leaves your machine"

if [ "$PICK_INDEX" -eq -1 ] || [ "$PICK_INDEX" -eq 1 ]; then
  _TEL_MODE="off"
else
  _TEL_MODE="anonymous"
fi
_cs_set_config "telemetry" "$_TEL_MODE"
touch "$STATE_DIR/.telemetry-prompted"

echo ""
if [ "$_TEL_MODE" = "anonymous" ]; then
  echo -e "   ${GREEN}✓${RESET}  telemetry: ${BOLD}anonymous${RESET}"
else
  echo -e "   ${GREEN}✓${RESET}  telemetry: ${BOLD}off${RESET}"
fi
echo ""
pause 0.3

echo -e "   ${DIM}─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─${RESET}"
echo ""

echo -e "   ${BOLD}what happens next${RESET}"
echo ""
echo -e "   ${CYAN}→${RESET}  drop a UI screenshot into claude code"
echo -e "      clearshot activates automatically"
echo ""
pause 0.3

echo -e "   ${DIM}─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─${RESET}"
echo ""
echo -e "   ${DIM}repo${RESET}    ${CYAN}github.com/udayanwalvekar/clearshot${RESET}"
echo -e "   ${DIM}author${RESET}  ${CYAN}udayan walvekar${RESET}"
echo ""
echo -e "   ${DIM}go break some UIs. clearshot's watching. 👀${RESET}"
echo ""
